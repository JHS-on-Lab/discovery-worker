# ================================================================
# 공통 기본값 — 변경이 없는 값은 여기서만 정의한다.
# 환경별로 달라지는 값은 .env.{APP_ENV} 에서만 설정한다.
# ================================================================

# Fetcher
DEFAULT_CRAWL_DELAY_MS=1000
DEFAULT_RENDER_MODE=static
PROXY_PROVIDER=direct
HTTP_VERIFY_SSL=true

# Google 발견 모드: search (기본) | rss (봇 차단 시 대안)
GOOGLE_DISCOVERY_MODE=search

# Daum 뉴스 수집 범위: true=전체 언론사, false=뉴스제휴 언론사만
DAUM_NEWS_ALL=true

# 소스별 발견 최대 페이지 수 (키워드 1회 실행당)
NAVER_MAX_PAGES=30
DAUM_MAX_PAGES=30
GOOGLE_MAX_PAGES=5
BAIDU_MAX_PAGES=5
NAVER_STOCK_MAX_PAGES=30
DUCKDUCKGO_MAX_PAGES=5

# Discovery retry / reschedule
DISCOVERY_403_RESCHEDULE_SEC=1800
BOT_DETECT_RETRY_SEC=1800

# Logging
LOG_DIR=./logs
LOG_LEVEL=INFO
LOG_ROTATION=daily
LOG_RETAIN_DAYS=30    # daily 모드: 며칠치 보관 (기본 30)
LOG_BACKUP_COUNT=10   # size 모드: 파일 몇 개 보관 (기본 10)
HEARTBEAT_INTERVAL_SECONDS=60
