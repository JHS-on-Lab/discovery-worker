# ================================================================
# 공통 기본값 — 민감 정보 없음. 환경별 접속 정보는 .env.{APP_ENV} 에 작성.
# 로컬 개인 설정은 .env.local (gitignore 됨).
# ================================================================

# RDS — 환경별 파일(.env.dev / .env.prod)에서 반드시 override
RDS_HOST=
RDS_PORT=3306
RDS_USER=
RDS_PASSWORD=
RDS_DB=keyword_collector

# Worker — 컨테이너 실행 시 주입. 미설정 시 이 기본값 사용 (로컬 단독 실행용).
WORKER_ID=worker-1

# Fetcher
DEFAULT_CRAWL_DELAY_MS=1000
DEFAULT_RENDER_MODE=static
PROXY_PROVIDER=direct

# Sink
SINK_TYPE=file
FILE_SINK_DIR=./output
LOG_DIR=./logs

# Solr (SINK_TYPE=solr 일 때만 필요)
# SOLR_URL=http://localhost:8983/solr/news
# SOLR_BATCH_SIZE=100
# SOLR_COMMIT_WITHIN_MS = 5000

# Retry / Backoff
MAX_ATTEMPTS=5
BACKOFF_BASE_SECONDS=30
BACKOFF_MAX_SECONDS=3600
CLAIM_TIMEOUT_SECONDS=300
DISCOVERY_403_RESCHEDULE_SEC=1800 # 30분 — 403 후 같은 키워드 재시도 유예

# Rules cache
RULES_CACHE_TTL_SECONDS=60

# Logging
LOG_LEVEL=INFO
LOG_ROTATION=daily
HEARTBEAT_INTERVAL_SECONDS=60

# 포털별 발견 최대 페이지 수 (키워드 1회 실행당)
NAVER_MAX_PAGES=30
DAUM_MAX_PAGES=30
GOOGLE_MAX_PAGES=5
BAIDU_MAX_PAGES=5
NAVER_STOCK_MAX_PAGES=30

# Daum 뉴스 수집 범위: true=전체 언론사, false=뉴스제휴 언론사만
DAUM_NEWS_ALL=true

# Google 발견 모드: search (기본) | rss (봇 차단 시 대안)
GOOGLE_DISCOVERY_MODE=search
