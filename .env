# ================================================================
# 공통 기본값 — 변경이 없는 값은 여기서만 정의한다.
# 환경별로 달라지는 값은 .env.{APP_ENV} 에서만 설정한다.
# 로컬 개인 설정은 .env.local (gitignore 대상).
# ================================================================

# RDS
RDS_PORT=3306
RDS_DB=keyword_crawler

# Solr (SINK_TYPE=solr 일 때만 필요)
# SOLR_URL 설정 시 직접 접속 / 없으면 SOLR_RUNTIME_NAME 으로 t_crawl_runtime 조회
SOLR_URL=
SOLR_RUNTIME_NAME=
SOLR_BATCH_SIZE=100
SOLR_COMMIT_WITHIN_MS=5000

# Sink
SINK_TYPE=file
FILE_SINK_DIR=./output

# Worker
WORKER_ID=worker-1

# Fetcher
DEFAULT_CRAWL_DELAY_MS=1000
DEFAULT_RENDER_MODE=static
PROXY_PROVIDER=direct
HTTP_VERIFY_SSL=true

# Google 발견 모드: search (기본) | rss (봇 차단 시 대안)
GOOGLE_DISCOVERY_MODE=search

# Daum 뉴스 수집 범위: true=전체 언론사, false=뉴스제휴 언론사만
DAUM_NEWS_ALL=true

# 소스별 발견 최대 페이지 수 (키워드 1회 실행당)
NAVER_MAX_PAGES=30
DAUM_MAX_PAGES=30
GOOGLE_MAX_PAGES=5
BAIDU_MAX_PAGES=5
NAVER_STOCK_MAX_PAGES=30

# Retry / Backoff
MAX_ATTEMPTS=5
BACKOFF_BASE_SECONDS=30
BACKOFF_MAX_SECONDS=3600
CLAIM_TIMEOUT_SECONDS=300
DISCOVERY_403_RESCHEDULE_SEC=1800

# Rules cache
RULES_CACHE_TTL_SECONDS=60

# Logging
LOG_DIR=./logs
LOG_LEVEL=INFO
LOG_ROTATION=daily
HEARTBEAT_INTERVAL_SECONDS=60
